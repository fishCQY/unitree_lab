<mujoco model="g1_29dof terrain scene">
  <include file="g1_29dof.xml"/>

  <statistic center="0 0 0.5" extent="2.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <!--
      Heightfield placeholder for sim2sim terrains.
      We overwrite model.hfield_data at runtime (see scripts/mujoco_eval/run_sim2sim_locomotion.py).
      size = sx sy sz base (MuJoCo): heights = base + sz * hfield_data, with hfield_data in [0,1].

      IMPORTANT:
      - Heightfields are finite in MuJoCo; make sx/sy large enough so the robot doesn't walk out.
      - Keep horizontal resolution reasonable (~0.1m) so obstacles don't collapse to 1-cell artifacts.
    -->
    <!-- NOTE: MuJoCo requires all 'size' params to be positive; keep base >= 0 and fit heights in code. -->
    <!-- MuJoCo expects all 4 size components to be strictly positive (including base). -->
    <!-- Use an in-XML placeholder (flat) and inject the actual terrain heights at runtime. -->
    <!--
      Match IsaacLab rough world scale more closely:
      - tile_size=8m, num_rows=10, num_cols=20, border_width=20m
      => world size = (20*8 + 2*20) x (10*8 + 2*20) = 200m x 120m
      Use ~0.1m resolution => 2001 x 1201 samples.
    -->
    <!-- Increase size_z so height variations are visually clearer in MuJoCo. -->
    <hfield name="terrain_hfield" nrow="1201" ncol="2001" size="100 60 1.0 0.001"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <!-- Use heightfield as the ground. -->
    <geom name="terrain" type="hfield" hfield="terrain_hfield" material="groundplane"
          friction="1 0.005 0.0001" contype="1" conaffinity="1"/>
  </worldbody>
</mujoco>


